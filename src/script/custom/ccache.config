# Standard Developer ccache config file. This changes within CI/CD.

CCACHE_HASHDIR=true
CCACHE_SLOPPINESS=time_macros
CCACHE_CPP2=true
CCACHE_RESHARE=true
CCACHE_REMOTE_STORAGE=redis://172.24.237.209:6379/0
CCACHE_REMOTE_ONLY=true

HOME=/tmp
XDG_CACHE_HOME=/tmp/.cache
CYPRESS_CACHE_FOLDER=/tmp/.cache/Cypress