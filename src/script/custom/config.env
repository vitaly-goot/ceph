# shellcheck shell=sh

# We don't care about unexported variables here.
# shellcheck disable=SC2034

# If 1, install recent ccache.
AKCEPH_ENABLE_CCACHE=1

# If 1, install recent Golang and configure some useful tools.
AKCEPH_ENABLE_GO=1

# If 1, compile gRPC and any sub-dependencies (e.g. abseil-cpp).
AKCEPH_ENABLE_GRPC=1

# If 1, compile OpenSSL 3 and any sub-dependencies (none so far).
AKCEPH_ENABLE_OPENSSL3=0

# Toolchain used for the custom Abseil/gRPC/OpenSSL dependencies.
AKCEPH_C_COMPILER=gcc-13
AKCEPH_CXX_COMPILER=g++-13

# Defaults for downstream package builds.  make-debs.sh exports these when
# the caller did not already provide the corresponding build variable.
AKCEPH_WITH_SPDK=ON
AKCEPH_CMAKE_INTERPROCEDURAL_OPTIMIZATION=ON

# If 1, repackage the ubuntu-toolchain-r/test PPA's libstdc++6/libgcc-s1 (the
# same PPA used to install AKCEPH_C_COMPILER/AKCEPH_CXX_COMPILER above) into a
# standalone "akceph-runtime-libstdcxx6" package at image-build time. make-debs.sh
# adds it to the package repo so GCC-13-built binaries find the GLIBCXX symbol
# versions they need on targets whose system libstdc++6 predates GCC 13.
AKCEPH_BUNDLE_RUNTIME_LIBSTDCXX=1

# Package builds with IPO/LTO can run several memory-heavy links at once.
# Cap make-debs.sh parallelism by default without changing optimization.
AKCEPH_PACKAGE_NPROC_MAX=${AKCEPH_PACKAGE_NPROC_MAX:-4}


# Cache version.
AKCEPH_CCACHE_VERSION=4.9.1
# Ccache gpg key ID. Marginally more secure than just setting
# '--auto-retrieve-key' on the gpg command line.
AKCEPH_CCACHE_GPGKEYID=996DDA075594ADB8

# Compiler -march= value.
AKCEPH_GCC_TARGET_ARCH=x86-64

# Compiler and linker flags shared by custom dependency builds.
AKCEPH_COMMON_FLAGS="-march=x86-64 -flto=auto -ffat-lto-objects"
AKCEPH_LINKER_FLAGS=

# OpenSSL has historically been sensitive to LTO.  Keep its optional custom
# build on conservative CFLAGS even when the CMake-based dependencies use LTO.
AKCEPH_OPENSSL_CFLAGS="-march=x86-64"

# The version of Golang to install. We're not doing anything avant garde here,
# and I don't expect the version to be too important.
AKCEPH_GOLANG_VERSION=1.23.4
# The checksum of the amd64 tarball for the above version.
AKCEPH_GOLANG_CHECKSUM=6924efde5de86fe277676e929dc9917d466efa02fb934197bc2eba35d5680971

# The version of gRPC to install.
AKCEPH_GRPC_VERSION=1.59.3

# Build external gRPC/abseil with C++20 so they match Ceph and
# opentelemetry-cpp in this tree.
CMAKE_CXX_STANDARD=20
